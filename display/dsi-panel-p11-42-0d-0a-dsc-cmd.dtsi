					39 00 00 40 00 00 02 D1 00
					//MIPI Error Gating Set For ESD
					//check MIPI HS timeout
					39 00 00 40 00 00 03 F0 AA 10
					39 00 00 40 00 00 02 65 0B
					39 00 00 40 00 00 03 CF DD 79
					39 00 00 40 00 00 03 FF 5A 00
					39 00 00 00 00 00 03 F0 AA 00
					//AOD ISOP/IGOP/Pump clk
					39 00 00 40 00 00 03 F0 AA 10
					39 00 00 40 00 00 02 65 0A
					39 00 00 40 00 00 07 C4 00 00 00 00 00 00
					39 00 00 40 00 00 02 65 11
					39 00 00 40 00 00 02 C4 00
					39 00 00 40 00 00 03 F0 AA 12
					39 00 00 40 00 00 0C B2 75 35 77 75 35 77 75 35 77 57 05
					39 00 00 00 00 00 03 F0 AA 00
					//MIPI ULPS error ESD off
					39 00 00 40 00 00 03 F0 AA 10
					39 00 00 40 00 00 02 65 09
					39 00 00 40 00 00 02 CF 5B
					39 00 00 00 00 00 03 F0 AA 00
		        ];
				qcom,mdss-dsi-on-command-state = "dsi_lp_mode";
                 qcom,mdss-dsi-timing-switch-command = [
					//60hz
					39 00 00 00 00 00 02 6C 01
				];
				qcom,mdss-dsi-timing-switch-command-state = "dsi_hs_mode";
				mi,mdss-dsi-csc-by-temper-comp-off-mode-command = [
					39 00 00 40 00 00 03 F0 AA 1A
					39 00 00 40 00 00 02 B0 01
					39 00 00 00 00 00 02 6B 00
					39 00 00 00 00 00 03 F0 AA 00
				];
				mi,mdss-dsi-csc-by-temper-comp-off-mode-command-state = "dsi_hs_mode";
				mi,mdss-dsi-csc-by-temper-comp-32-36-mode-command = [
					39 00 00 40 00 00 03 F0 AA 1A
					39 00 00 40 00 00 02 B0 01
					39 00 00 00 00 00 02 6B 01
					39 00 00 00 00 00 03 F0 AA 00
				];
				mi,mdss-dsi-csc-by-temper-comp-32-36-mode-command-state = "dsi_hs_mode";
				mi,mdss-dsi-csc-by-temper-comp-36-40-mode-command = [
					39 00 00 40 00 00 03 F0 AA 1A
					39 00 00 40 00 00 02 B0 01
					39 00 00 00 00 00 02 6B 03
					39 00 00 00 00 00 03 F0 AA 00
				];
				mi,mdss-dsi-csc-by-temper-comp-36-40-mode-command-state = "dsi_hs_mode";
				mi,mdss-dsi-csc-by-temper-comp-40-mode-command = [
					39 00 00 40 00 00 03 F0 AA 1A
					39 00 00 40 00 00 02 B0 01
					39 00 00 00 00 00 02 6B 05
					39 00 00 00 00 00 03 F0 AA 00
				];
				mi,mdss-dsi-csc-by-temper-comp-40-mode-command-state = "dsi_hs_mode";
				mi,mdss-dsi-csc-by-temper-comp-45-mode-command = [
					39 00 00 40 00 00 03 F0 AA 1A
					39 00 00 40 00 00 02 B0 01
					39 00 00 00 00 00 02 6B 07
					39 00 00 00 00 00 03 F0 AA 00
				];
				mi,mdss-dsi-csc-by-temper-comp-45-mode-command-state = "dsi_hs_mode";
			};
		};
	};
};

&dsi_p11_42_0d_0a_dsc_cmd {
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply_p11>;
	qcom,mdss-dsi-bl-pmic-control-type = "bl_ctrl_dcs";
	qcom,mdss-dsi-bl-min-level = <5>;
	qcom,mdss-dsi-bl-max-level = <16383>;
	qcom,bl-dsc-cmd-state = "dsi_hs_mode";
	qcom,mdss-brightness-max-level = <16383>;
	qcom,mdss-brightness-init-level = <858>;
	qcom,platform-reset-gpio = <&tlmm 98 0>;

	mi,max-brightness-normal = <6750>;

	mi,panel-build-id-read-needed;
	mi,panel-build-id-read-length = <1>;
	mi,mdss-dsi-panel-build-id-read-command = [06 01 00 01 00 00 01 DA];
	mi,mdss-dsi-panel-build-id-read-command-state = "dsi_hs_mode";

	qcom,mdss-dsi-panel-vsync-delay;
	qcom,ulps-enabled;
	qcom,dsi-select-clocks = "pll_byte_clk0", "pll_dsi_clk0";
	qcom,mdss-dsi-clk-strength = <0x88>;
};
