			timing@wqhd_normal_120hz_index_01 {
				#include "dsi-panel-o2-42-02-0a-dsc-cmd-common.dtsi"
				cell-index = <0>;
				qcom,mdss-dsi-panel-framerate = <120>;
				qcom,qsync-mode-min-refresh-rate = <1>;
				qcom,dsi-qsync-mode-avr-step-fps = <120>;

				qcom,mdss-dsi-video-mode;
				qcom,mdss-dsi-on-command = [
					//1440x3200
					39 00 00 40 00 00 06 F0 55 AA 52 08 01
					15 00 00 40 00 00 02 6F 06
