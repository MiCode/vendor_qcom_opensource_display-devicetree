					39 00 00 40 00 00 06 F0 55 AA 52 08 00
					15 00 00 40 00 00 02 6F 03
					15 00 00 40 00 00 02 BE 4F
					15 00 00 40 00 00 02 6F 0B
					15 00 00 00 00 00 02 BE 02
					//120HZ
					15 00 00 40 00 00 02 2F 30
					15 00 00 00 00 00 02 6D 00
					//fix TE
					15 00 00 40 00 00 02 6F 14
					15 00 00 40 00 00 02 35 66
					15 00 00 40 00 00 02 6F 04
					15 00 00 40 00 00 02 35 00
					15 00 00 00 00 00 02 5A 00
