&dsi_o2_42_02_0a_dsc_cmd {
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply_O2>;
	qcom,mdss-dsi-bl-pmic-control-type = "bl_ctrl_dcs";
	qcom,mdss-dsi-bl-min-level = <15>;
	qcom,mdss-dsi-bl-max-level = <16383>;
	qcom,bl-dsc-cmd-state = "dsi_hs_mode";
	qcom,mdss-brightness-max-level = <16383>;
	qcom,mdss-brightness-init-level = <614>;
	qcom,platform-reset-gpio = <&tlmm 98 0>;

	mi,max-brightness-normal = <5460>;

	qcom,mdss-dsi-panel-vsync-delay;
	//qcom,ulps-enabled;
	qcom,dsi-select-clocks = "pll_byte_clk0", "pll_dsi_clk0";

	qcom,mdss-esync;
	qcom,mdss-esync-always-on;
	qcom,mdss-esync-hsync-milli-pulse-width = <500>;
	qcom,mdss-esync-emsync-milli-pulse-width = <500>;
	qcom,mdss-esync-emsync-fps = <120>;

	qcom,qsync-enable;
	qcom,vrr-enable;
	qcom,video-psr-enable;

	qcom,dsi-qsync-avr-disable-hw-trigger;
	qcom,mdss-dsi-qsync-min-refresh-rate = <1>;
	qcom,dsi-qsync-avr-step-fps = <120>;
};
