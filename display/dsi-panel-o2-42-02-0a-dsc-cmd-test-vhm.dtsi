				qcom,mdss-dsi-sticky_still_en-command =
					[39 01 00 00 00 00 02 18 01];

				qcom,mdss-dsi-sticky_still_disable-command =
					[39 01 00 00 00 00 02 18 00];
				qcom,mdss-dsi-sticky_still_en-command-state = "dsi_hs_mode";
				qcom,mdss-dsi-sticky_still_disable-command-state = "dsi_hs_mode";

